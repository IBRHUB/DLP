{
  "manifest_version": 3,
  "name": "DLP",
  "description": "Send supported media URLs to DLP Developed by IBRAHIM",
  "version": "1.0.0",
  "homepage_url": "https://ibrhub.net",
  "key": "",
  "permissions": [
    "contextMenus",
    "nativeMessaging",
    "storage",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "*://youtube.com/*",
    "*://www.youtube.com/*",
    "*://m.youtube.com/*",
    "*://youtu.be/*",
    "*://tiktok.com/*",
    "*://www.tiktok.com/*",
    "*://m.tiktok.com/*",
    "*://vm.tiktok.com/*",
    "*://vt.tiktok.com/*",
    "*://instagram.com/*",
    "*://www.instagram.com/*",
    "*://m.instagram.com/*",
    "*://x.com/*",
    "*://www.x.com/*",
    "*://mobile.x.com/*",
    "*://twitter.com/*",
    "*://www.twitter.com/*",
    "*://mobile.twitter.com/*",
    "*://soundcloud.com/*",
    "*://www.soundcloud.com/*",
    "*://m.soundcloud.com/*",
    "*://on.soundcloud.com/*",
    "file:///*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "DLP",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true
    }
  ]
}
